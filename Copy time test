function main(workbook: ExcelScript.Workbook) {
  // התחלת מדידת זמן
  let startTime = new Date().getTime();
  
  console.log("מתחיל בתהליך הסריקה (עמודות M,N -> O,P)...");

  const sheet = workbook.getActiveWorksheet();
  const usedRange = sheet.getUsedRange();

  if (!usedRange) {
    console.log("הגיליון ריק. מסיים ריצה.");
    return;
  }

  // חישוב גודל הטווח
  const lastRowIndex = usedRange.getLastRow().getRowIndex();
  // סך הכל שורות לעיבוד (מתחילים משורה 2, ולכן אינדקס 1)
  const rowCount = lastRowIndex; 

  if (rowCount < 1) {
    console.log("אין מספיק נתונים לעיבוד (פחות מ-2 שורות).");
    return;
  }

  console.log(`נמצאו ${rowCount} שורות לעיבוד. טוען נתונים לזיכרון...`);

  // --- שינוי הגדרת העמודות החדשות ---
  // עמודות מקור: M (אינדקס 12), N (אינדקס 13)
  // עמודות יעד: O (אינדקס 14), P (אינדקס 15)

  const sourceRange = sheet.getRangeByIndexes(1, 12, rowCount, 2); // עמודות מקור M, N
  const targetRange = sheet.getRangeByIndexes(1, 14, rowCount, 2); // עמודות יעד O, P

  // טעינת הערכים
  const sourceValues = sourceRange.getValues();
  const targetValues = targetRange.getValues();

  // הגדרות לוגיקה
  const zPattern = /z/i; // ביטוי רגולרי לחיפוש z (מתעלם מ-Case)
  let hasChanges = false;
  
  // מונים לסטטיסטיקה
  let countChangedO = 0;
  let countChangedP = 0;
  
  // דיווח כל 200 שורות
  const logBatchSize = 200; 

  console.log("הנתונים נטענו בהצלחה, מתחיל בעיבוד השורות...");

  // לולאה ראשית
  for (let i = 0; i < rowCount; i++) {
    
    // שליפת הערכים מהמערך בזיכרון
    // אינדקס 0 במערך המקומי = העמודה השמאלית בטווח (O או M)
    // אינדקס 1 במערך המקומי = העמודה הימנית בטווח (P או N)
    
    let valO = targetValues[i][0]; // הערך הנוכחי בעמודה O
    let valP = targetValues[i][1]; // הערך הנוכחי בעמודה P
    let rowChanged = false;

    // --- בדיקה עבור עמודה O (העתקה מ-M) ---
    if (typeof valO === 'string' && zPattern.test(valO)) {
      targetValues[i][0] = sourceValues[i][0]; // העתקה מ-M אל O
      countChangedO++;
      rowChanged = true;
    }

    // --- בדיקה עבור עמודה P (העתקה מ-N) ---
    if (typeof valP === 'string' && zPattern.test(valP)) {
      targetValues[i][1] = sourceValues[i][1]; // העתקה מ-N אל P
      countChangedP++;
      rowChanged = true;
    }

    // סימון כללי שיש צורך בשמירה בסוף
    if (rowChanged) {
      hasChanges = true;
    }

    // הדפסת התקדמות לקונסול כל 200 שורות
    if ((i + 1) % logBatchSize === 0) {
      console.log(`...מעבד... הושלמו ${i + 1} שורות מתוך ${rowCount}`);
    }
  }

  // שלב השמירה: כותבים לאקסל רק אם באמת בוצע שינוי כלשהו
  if (hasChanges) {
    console.log("סיימתי עיבוד. כותב את השינויים חזרה לאקסל (עמודות O, P)...");
    targetRange.setValues(targetValues);
  } else {
    console.log("לא נמצאה האות 'z' באף תא בעמודות O או P. לא בוצעה כתיבה.");
  }

  // חישוב זמנים וסיכום
  let endTime = new Date().getTime();
  let duration = (endTime - startTime) / 1000; // המרה לשניות

  console.log("-----------------------------------------");
  console.log("             סיכום ביצוע                 ");
  console.log("-----------------------------------------");
  console.log(`סה"כ שורות שנבדקו: ${rowCount}`);
  console.log(`החלפות שבוצעו בעמודה O (מקור M): ${countChangedO}`);
  console.log(`החלפות שבוצעו בעמודה P (מקור N): ${countChangedP}`);
  console.log(`סה"כ החלפות: ${countChangedO + countChangedP}`);
  console.log(`זמן ריצה כולל: ${duration} שניות`);
  console.log("-----------------------------------------");
}
