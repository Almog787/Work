function main(workbook: ExcelScript.Workbook) {
  // Start time measurement
  let startTime = new Date().getTime();
  
  console.log("Starting scan process (Columns L,M -> N,O)...");

  const sheet = workbook.getActiveWorksheet();
  const usedRange = sheet.getUsedRange();

  if (!usedRange) {
    console.log("Sheet is empty. Exiting.");
    return;
  }

  // Calculate range size
  const lastRowIndex = usedRange.getLastRow().getRowIndex();
  // Total rows to process (starting from row 2, so index 1)
  const rowCount = lastRowIndex; 

  if (rowCount < 1) {
    console.log("Not enough data to process (less than 2 rows).");
    return;
  }

  console.log(`Found ${rowCount} rows to process. Loading data to memory...`);

  // --- Define new column configuration ---
  // Source columns: L (index 11), M (index 12)
  // Target columns: N (index 13), O (index 14)

  const sourceRange = sheet.getRangeByIndexes(1, 11, rowCount, 2); // Source columns L, M
  const targetRange = sheet.getRangeByIndexes(1, 13, rowCount, 2); // Target columns N, O

  // Load values
  const sourceValues = sourceRange.getValues();
  const targetValues = targetRange.getValues();

  // Logic configurations
  const zPattern = /z/i; // Regular expression to search for 'z' (case-insensitive)
  let hasChanges = false;
  
  // Counters for statistics
  let countChangedN = 0;
  let countChangedO = 0;
  
  // Report every 200 rows
  const logBatchSize = 200; 

  console.log("Data loaded successfully, starting row processing...");

  // Main loop
  for (let i = 0; i < rowCount; i++) {
    
    // Fetch values from the array in memory
    // Local array index 0 = Left column in range (L or N)
    // Local array index 1 = Right column in range (M or O)
    
    let valN = targetValues[i][0]; // Current value in column N
    let valO = targetValues[i][1]; // Current value in column O
    let rowChanged = false;

    // --- Check for column N (Copy from L) ---
    if (typeof valN === 'string' && zPattern.test(valN)) {
      targetValues[i][0] = sourceValues[i][0]; // Copy from L to N
      countChangedN++;
      rowChanged = true;
    }

    // --- Check for column O (Copy from M) ---
    if (typeof valO === 'string' && zPattern.test(valO)) {
      targetValues[i][1] = sourceValues[i][1]; // Copy from M to O
      countChangedO++;
      rowChanged = true;
    }

    // General flag for saving at the end
    if (rowChanged) {
      hasChanges = true;
    }

    // Print progress to console every 200 rows
    if ((i + 1) % logBatchSize === 0) {
      console.log(`...Processing... Completed ${i + 1} rows out of ${rowCount}`);
    }
  }

  // Save phase: write back to Excel only if a change occurred
  if (hasChanges) {
    console.log("Processing finished. Writing changes back to Excel (Columns N, O)...");
    targetRange.setValues(targetValues);
  } else {
    console.log("The letter 'z' was not found in any cell in columns N or O. No writing performed.");
  }

  // Calculate time and summary
  let endTime = new Date().getTime();
  let duration = (endTime - startTime) / 1000; // Convert to seconds

  console.log("-----------------------------------------");
  console.log("             Execution Summary           ");
  console.log("-----------------------------------------");
  console.log(`Total rows checked: ${rowCount}`);
  console.log(`Replacements made in column N (Source L): ${countChangedN}`);
  console.log(`Replacements made in column O (Source M): ${countChangedO}`);
  console.log(`Total replacements: ${countChangedN + countChangedO}`);
  console.log(`Total run time: ${duration} seconds`);
  console.log("-----------------------------------------");
}
