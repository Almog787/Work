function main(workbook: ExcelScript.Workbook) {
  // התחלת מדידת זמן
  let startTime = new Date().getTime();
  
  console.log("מתחיל בתהליך הסריקה (עמודות X,Y -> BC,BD)...");

  const sheet = workbook.getActiveWorksheet();
  const usedRange = sheet.getUsedRange();

  if (!usedRange) {
    console.log("הגיליון ריק. מסיים ריצה.");
    return;
  }

  // חישוב גודל הטווח
  const lastRowIndex = usedRange.getLastRow().getRowIndex();
  // סך הכל שורות לעיבוד (מתחילים משורה 2, כלומר אינדקס 1)
  const rowCount = lastRowIndex; 

  if (rowCount < 1) {
    console.log("אין מספיק נתונים לעיבוד (פחות מ-2 שורות).");
    return;
  }

  console.log(`נמצאו ${rowCount} שורות לעיבוד. טוען נתונים לזיכרון...`);

  // --- שינוי הגדרת העמודות החדשות ---
  // עמודות מקור: X (אינדקס 23), Y (אינדקס 24)
  // עמודות יעד: BC (אינדקס 54), BD (אינדקס 55)

  const sourceRange = sheet.getRangeByIndexes(1, 23, rowCount, 2); // עמודות מקור X, Y
  const targetRange = sheet.getRangeByIndexes(1, 54, rowCount, 2); // עמודות יעד BC, BD

  // טעינת הערכים
  const sourceValues = sourceRange.getValues();
  const targetValues = targetRange.getValues();

  // הגדרות לוגיקה
  const zPattern = /z/i; // ביטוי רגולרי לחיפוש z (מתעלם מ-Case)
  let hasChanges = false;
  
  // מונים לסטטיסטיקה
  let countChangedBC = 0;
  let countChangedBD = 0;
  
  // דיווח כל 200 שורות
  const logBatchSize = 200; 

  console.log("הנתונים נטענו בהצלחה, מתחיל בעיבוד השורות...");

  // לולאה ראשית
  for (let i = 0; i < rowCount; i++) {
    
    // שליפת הערכים מהמערך בזיכרון
    // אינדקס 0 במערך המקומי = העמודה השמאלית בטווח (BC או X)
    // אינדקס 1 במערך המקומי = העמודה הימנית בטווח (BD או Y)
    
    let valBC = targetValues[i][0]; // הערך הנוכחי בעמודה BC
    let valBD = targetValues[i][1]; // הערך הנוכחי בעמודה BD
    let rowChanged = false;

    // --- בדיקה עבור עמודה BC (העתקה מ-X) ---
    if (typeof valBC === 'string' && zPattern.test(valBC)) {
      targetValues[i][0] = sourceValues[i][0]; // העתקה מ-X
      countChangedBC++;
      rowChanged = true;
    }

    // --- בדיקה עבור עמודה BD (העתקה מ-Y) ---
    if (typeof valBD === 'string' && zPattern.test(valBD)) {
      targetValues[i][1] = sourceValues[i][1]; // העתקה מ-Y
      countChangedBD++;
      rowChanged = true;
    }

    // סימון כללי שיש צורך בשמירה בסוף
    if (rowChanged) {
      hasChanges = true;
    }

    // הדפסת התקדמות לקונסול כל 200 שורות
    if ((i + 1) % logBatchSize === 0) {
      console.log(`...מעבד... הושלמו ${i + 1} שורות מתוך ${rowCount}`);
    }
  }

  // שלב השמירה: כותבים לאקסל רק אם באמת בוצע שינוי כלשהו
  if (hasChanges) {
    console.log("סיימתי עיבוד. כותב את השינויים חזרה לאקסל (עמודות BC, BD)...");
    targetRange.setValues(targetValues);
  } else {
    console.log("לא נמצאה האות 'z' באף תא בעמודות BC או BD. לא בוצעה כתיבה.");
  }

  // חישוב זמנים וסיכום
  let endTime = new Date().getTime();
  let duration = (endTime - startTime) / 1000; // המרה לשניות

  console.log("-----------------------------------------");
  console.log("             סיכום ביצוע                 ");
  console.log("-----------------------------------------");
  console.log(`סה"כ שורות שנבדקו: ${rowCount}`);
  console.log(`החלפות שבוצעו בעמודה BC (מקור X): ${countChangedBC}`);
  console.log(`החלפות שבוצעו בעמודה BD (מקור Y): ${countChangedBD}`);
  console.log(`סה"כ החלפות: ${countChangedBC + countChangedBD}`);
  console.log(`זמן ריצה כולל: ${duration} שניות`);
  console.log("-----------------------------------------");
}
